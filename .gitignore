# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# estado local da instalação (cada cliente mantém o próprio; ver configuracao-estado-example.md)
configuracao-estado.md

# config MCP do projeto — cada cliente aponta pro próprio Supabase project_ref; ver .mcp.example.json
.mcp.json

# settings locais do Claude Code (preferências/permissões da máquina; nunca compartilhar)
.claude/settings.local.json
